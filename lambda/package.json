{
  "name": "tax4sure-lambda",
  "version": "1.0.0",
  "private": true,
  "description": "Tax4Sure API Lambda function",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "package": "npm run build && cd dist && zip -r ../lambda.zip . && cd .. && zip -r lambda.zip node_modules -x '*.ts'"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
