# =============================================================================
# Tax4Sure – Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
# Table: partition key = "username" (String), GSI "EmailIndex" on "email" (String)
DYNAMODB_TABLE_NAME=tax4sure-users

# ─── S3 Document Storage (private bucket) ────────────────────────────────────
S3_BUCKET_NAME=tax4sure-documents

# ─── JWT Secret ───────────────────────────────────────────────────────────────
# Used to sign auth tokens — set the same value in Lambda env vars
JWT_SECRET=your_random_secret_at_least_32_chars_long

# ─── Lambda Function URL ──────────────────────────────────────────────────────
# Output from: terraform output lambda_function_url (or copy from AWS console)
NEXT_PUBLIC_API_URL=https://xxxxxxxx.lambda-url.us-east-1.on.aws

# ─── Gmail — Contact Form Email ───────────────────────────────────────────────
# The Gmail account that SENDS emails. Must have 2-Step Verification enabled.
# To get App Password: myaccount.google.com → Security → App passwords → create one
GMAIL_USER=tax4sureca@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Where contact form submissions are delivered
CONTACT_EMAIL=tax4sureca@gmail.com
