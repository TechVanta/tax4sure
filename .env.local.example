# =============================================================================
# Tax4Sure – Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# ─── AWS Credentials (IAM user with DynamoDB + S3 permissions) ───────────────
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1

# ─── DynamoDB ────────────────────────────────────────────────────────────────
# Table: partition key = "username" (String), GSI "EmailIndex" on "email" (String)
DYNAMODB_TABLE_NAME=tax4sure-users

# ─── S3 Document Storage (private bucket) ────────────────────────────────────
S3_BUCKET_NAME=tax4sure-documents

# ─── Lambda JWT Secret ───────────────────────────────────────────────────────
# Used to sign auth tokens — set the same value in Lambda env vars via Terraform
JWT_SECRET=your_random_secret_at_least_32_chars_long

# ─── Next.js Frontend ────────────────────────────────────────────────────────
# Lambda Function URL — output from: terraform output lambda_function_url
NEXT_PUBLIC_API_URL=https://xxxxxxxx.lambda-url.us-east-1.on.aws

# Local dev only — not used in static export
NEXTAUTH_URL=http://localhost:3000
